# Neo4j — AuraDB free tier: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kospassword

# ChromaDB — use "embedded" (default) or "http" for a separate ChromaDB server
CHROMA_MODE=embedded
CHROMA_DATA_DIR=./chroma_data
# Only used when CHROMA_MODE=http:
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# Set to "true" on first deploy to load fixture data into an empty database
SEED_ON_STARTUP=false

# Comma-separated allowed CORS origins, or "*" to allow all
ALLOWED_ORIGINS=*

KOS_ENV=development
